# ============================================================
# AI Fraud Detector - API Keys Configuration
# ============================================================
# Copy this file to .env and fill in your API keys
# cp .env.example .env

# --- Hugging Face ---
# Sign up: https://huggingface.co/join
# Get token: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- MeaningCloud ---
# Sign up: https://www.meaningcloud.com/developer/login
MEANINGCLOUD_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- IPQualityScore ---
# Sign up: https://www.ipqualityscore.com/create-account
IPQUALITYSCORE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Google Safe Browsing ---
# Enable API: https://console.cloud.google.com/apis/library/safebrowsing.googleapis.com
GOOGLE_SAFE_BROWSING_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- VirusTotal ---
# Sign up: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- PhishTank ---
# Sign up: https://www.phishtank.com/register.php (optional, public API works without key)
PHISHTANK_APP_KEY=

# --- Telegram Bot ---
# Create bot: Open Telegram -> search @BotFather -> /newbot -> copy the token
TELEGRAM_BOT_TOKEN=botXXXXXXXXXX:AAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Gemini AI ---
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- LibreTranslate ---
# Option 1: Use public server (may rate limit): https://libretranslate.com
# Option 2: Self-host: https://github.com/LibreTranslate/LibreTranslate
LIBRETRANSLATE_URL=https://libretranslate.com
LIBRETRANSLATE_API_KEY=

# --- App Settings ---
# Set to 1 to skip DB connections during local testing
SKIP_DB=1

# Enable/disable individual APIs (set to 0 to skip if you don't have a key yet)
USE_HUGGINGFACE=1
USE_MEANINGCLOUD=1
USE_IPQUALITYSCORE=1
USE_GOOGLE_SAFE_BROWSING=1
USE_VIRUSTOTAL=1
USE_PHISHTANK=1
USE_LIBRETRANSLATE=1
USE_TELEGRAM_BOT=0
